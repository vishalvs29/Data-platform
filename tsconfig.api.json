{
    "compilerOptions": {
        "target": "ESNext",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist/api",
        "rootDir": ".",
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "src/**/*.ts",
        "config/**/*.ts"
    ],
    "exclude": [
        "src/dashboard/**/*"
    ]
}