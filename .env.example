# ============================================================
# DrMindit — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Your Supabase project URL (found in Project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anonymous (public) key — safe for client-side
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── AI Services ─────────────────────────────────────────────
# Claude API key — SERVER SIDE ONLY via Supabase Edge Function.
# Do NOT prefix with EXPO_PUBLIC_; never expose to the client.
CLAUDE_API_KEY=your_claude_api_key_here

# ElevenLabs API key — SERVER SIDE ONLY
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
